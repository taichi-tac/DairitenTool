# ============================================================
# KDP代理店書籍自動化パイプライン - 環境変数設定例
# cp .env.example .env してから各値を設定してください
# ============================================================

# === Claude API ===
ANTHROPIC_API_KEY=sk-ant-api03-...

# === OpenAI (カバー画像生成 DALL-E 3) ===
OPENAI_API_KEY=sk-proj-...

# === Supabase ===
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_KEY=eyJ...

# === メール通知 (Resend) ===
RESEND_API_KEY=re_...
NOTIFICATION_FROM_EMAIL=noreply@yourcourse.jp

# === コース設定 ===
# トラッキングURL: {COURSE_BASE_URL}/r/{affiliate_id}
COURSE_BASE_URL=https://yourcourse.jp
COURSE_NAME=初心者向けAI副業オンライン講座

# === Slack通知（品質ゲート失敗・エラー時） ===
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/T.../B.../...

# === ストレージ（Cloudflare R2 - S3互換） ===
R2_ACCESS_KEY_ID=...
R2_SECRET_ACCESS_KEY=...
R2_BUCKET_NAME=kdp-books
R2_ENDPOINT=https://xxxxxxxxxx.r2.cloudflarestorage.com

# === ローカル開発用出力ディレクトリ ===
OUTPUT_DIR=/tmp/kdp-output
